# 量化选股推送服务配置
# 复制此文件为 .env 并填入实际配置
# .env 已在 .gitignore 中，不会被提交

# ===== 必需配置 =====

# Bark 推送 Key (为空则不会请求 Bark API，只在日志里输出荐股内容)
BARK_KEY=

# SiliconFlow API Key (AI Agent 需要)
SILICONFLOW_API_KEY=

# ===== 可选配置 =====

# 推送时间 格式: HH:MM
PUSH_TIME_MORNING=09:25
PUSH_TIME_AFTERNOON=13:25

# 新闻报告时间 (AI Agent 综合分析全球金融、政策和个股资讯后推送)
NEWS_REPORT_TIME=09:00

# AI Agent 增强分析
ENABLE_AI_AGENT=true
SILICONFLOW_MODEL=Pro/MiniMaxAI/MiniMax-M2.5

# SQLite数据库路径
# Docker环境默认: /app/runtime/data/recommend.db
DATABASE_PATH=

# 聚宽数据源 (可选，用于替代 akshare)
# 官网: https://www.joinquant.com
# JQ_USERNAME=
# JQ_PASSWORD=

# 富途 OpenD 数据源
# 本地开发: 127.0.0.1
# NAS虚拟机/生产部署: 192.168.5.6
FUTU_HOST=127.0.0.1
FUTU_PORT=11111

# 日志级别
LOG_LEVEL=INFO

# ===== TradingAgents (可选) =====
# TauricResearch/TradingAgents 用于增强分析：单股深度分析、大盘情绪、新闻/情绪/风险等
#
# 依赖模型提供方的 Key（例如 openai/openrouter），按 TradingAgents 的 llm_provider 选择配置
# 常用: OPENAI_API_KEY / OPENROUTER_API_KEY 等
#
# TRADINGAGENTS_LLM_PROVIDER=openai
# TRADINGAGENTS_BACKEND_URL=https://api.siliconflow.cn/v1
# TRADINGAGENTS_DEEP_MODEL=gpt-5.2
# TRADINGAGENTS_QUICK_MODEL=gpt-5-mini
# TRADINGAGENTS_MAX_DEBATE_ROUNDS=1
# TRADINGAGENTS_ONLINE_TOOLS=true
#
# 注意：当 TRADINGAGENTS_LLM_PROVIDER=openai 且使用 SiliconFlow 的 OpenAI 兼容接口时，
# TradingAgents/ChatOpenAI 默认读取 OPENAI_API_KEY（不是 SILICONFLOW_API_KEY）。
# 请额外设置：
# OPENAI_API_KEY=$SILICONFLOW_API_KEY
