# 量化选股推送服务配置
# 复制此文件为 .env 并填入实际配置

# Bark 推送 Key (可选；为空则不会请求 Bark API，只在日志里输出荐股内容)
BARK_KEY=

# 推送时间 (可选)
# 格式: HH:MM
PUSH_TIME_MORNING=09:25
PUSH_TIME_AFTERNOON=13:25

# SQLite数据库路径 (可选)
# Docker环境默认: /app/runtime/data/recommend.db
# 本地环境默认: ./data/recommend.db
DATABASE_PATH=

# 日志级别
LOG_LEVEL=INFO
