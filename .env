# 量化选股推送服务配置
# .env 随代码部署，CI 通过 sed 注入实际密钥
# 不包含真实密钥，真实密钥通过 Gitea Secrets 配置

# ===== 推送配置 =====
BARK_KEY=changeme
SERVERCHAN_SENDKEY=changeme
PUSH_TIME_MORNING=09:28
PUSH_TIME_AFTERNOON=13:10
PUSH_TIME_CLOSE=15:30
INTRADAY_TRAP_PUSH_TIMES=09:45,10:00,10:30,10:45,11:30,13:15,13:45,14:15,14:30,14:45,15:00

# ===== 新闻报告 =====
NEWS_REPORT_TIME=09:25

# ===== AI Agent =====
ENABLE_AI_AGENT=true
SILICONFLOW_API_KEY=changeme
SILICONFLOW_MODEL=Pro/MiniMaxAI/MiniMax-M2.5

# ===== 日志 =====
LOG_LEVEL=INFO

# ===== 富途 OpenD =====
FUTU_HOST=127.0.0.1
FUTU_PORT=11111

# ===== 东方财富 ==== 
